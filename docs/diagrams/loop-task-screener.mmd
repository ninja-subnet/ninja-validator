%%{init: {"theme": "base", "themeVariables": {"fontSize": "15px"}}}%%
flowchart TB
    start(["task-screener.main()"])
    start --> pending["Read reigning king's PENDING_SCREEN tasks<br/>with pending task_screenings rows"]
    pending --> reconcile["Cancel obsolete in-flight work;<br/>start up to configured concurrency"]
    reconcile --> injection{"qualification patch contains<br/>prompt injection?"}
    injection -- yes --> blocked["DISQUALIFIED<br/>reason = prompt_injection"]
    injection -- no --> score["Single-candidate LLM score<br/>task + qualification patch<br/>0–100 normalized to 0–1"]
    score --> error{"all routes failed or<br/>response invalid?"}
    error -- yes --> retry["Record error telemetry;<br/>leave PENDING_SCREEN for retry"]
    error -- no --> ceiling{"king score &gt;<br/>TAU_TASK_SCREEN_MAX_KING_SCORE?"}
    ceiling -- yes --> tooeasy["DISQUALIFIED<br/>reason = score_above_max"]
    ceiling -- no --> qualified["QUALIFIED<br/>eligible for duel solves"]
    blocked --> sleep["sleep TAU_TASK_SCREEN_POLL_SECONDS"]
    retry --> sleep
    tooeasy --> sleep
    qualified --> sleep
    sleep --> pending
