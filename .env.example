# Copy to .env and adjust. Never commit the real .env.

# --- Database credentials (used by the postgres image on first init) ---------
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=arena
POSTGRES_PORT=5432

# --- Read-only monitoring role created by initdb/00_init.sh ------------------
MONITOR_PASSWORD=change-me-monitor-password

# --- Alembic when run OUTSIDE docker (host -> container) ----------------------
# Inside docker compose each worker gets DATABASE_URL pointing at the `db` service,
# so you usually do not set this. Uncomment to run Alembic from your laptop:
# DATABASE_URL=postgresql+psycopg://appuser:change-me-strong-password@localhost:5432/arena

GITHUB_TOKEN=replace-with-github-token

# --- Chain-watcher worker ---
LOG_LEVEL=INFO
BITTENSOR_NETWORK=finney
# Archive node used to read historical registration block times (registration
# blocks are usually older than a lite node's ~300-block pruned-state window).
BITTENSOR_ARCHIVE_NETWORK=archive
# --- Throwaway DB for the Postgres-gated tests (tests/test_db_generator.py) ----
# A SEPARATE database from POSTGRES_DB (which holds real data): the suite DROPS &
# RECREATES the schema around every test, so it must never point at your dev DB.
# The suite auto-loads this .env, CREATEs `tau_pytest` on first run if missing, and
# skips unless the Postgres server is reachable.
TAU_TEST_DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/tau_pytest

# --- GitHub tokens for the commit sampler ------------------------------------
# The sampler rotates tokens round-robin and cools each one down independently on a
# rate-limit (per GitHub's reset headers) or a 401. Define one var per token, then
# compose GITHUB_TOKENS (comma-separated). For a single token, just set GITHUB_TOKEN.
GITHUB_TOKEN_ALICE=replace-with-github-token-alice
GITHUB_TOKEN_BOB=replace-with-github-token-bob
GITHUB_TOKENS="${GITHUB_TOKEN_ALICE},${GITHUB_TOKEN_BOB}"
# GITHUB_TOKEN=replace-with-github-token

# --- OpenRouter (task-generator LLM) -----------------------------------------
# Required UNLESS TAU_GENERATOR_USE_DUMMY_LLM=1 (see below). Key from openrouter.ai.
OPENROUTER_API_KEY=replace-with-openrouter-key

# --- chain-watcher worker (bittensor) ----------------------------------------
# Defaults shown; override only to point at a different network / subnet.
# BITTENSOR_NETWORK=finney
# NETUID=66

# --- task-generator worker (tuning; defaults shown, all optional) ------------
TAU_GENERATOR_MODEL=deepseek/deepseek-v4-pro
TAU_GENERATOR_DESCRIBE_CONCURRENCY=5   # concurrent describer coroutines
TAU_GENERATOR_LLM_ATTEMPTS=2           # LLM tries per commit before a fresh one
TAU_GENERATOR_LLM_TIMEOUT=120          # per-attempt LLM timeout (seconds)
TAU_GENERATOR_POLL_SECONDS=30          # idle sleep between controller polls

# Token-free dummy LLM for testing: mine real commits but fabricate descriptions
# locally, spending zero LLM tokens (OPENROUTER_API_KEY not required). Off by
# default. Latency = log-normal body (avg + sigma) + a slow mixture: slow_rate of
# calls land in [timeout, timeout*outlier_factor] and trip the per-attempt timeout;
# failure_rate of calls return unusable output (exercises the retry path).
# TAU_GENERATOR_USE_DUMMY_LLM=1
# TAU_GENERATOR_DUMMY_AVG_LATENCY=2      # median body latency (seconds)
# TAU_GENERATOR_DUMMY_LATENCY_SIGMA=0.4  # log-space spread of the body
# TAU_GENERATOR_DUMMY_SLOW_RATE=0.05     # fraction of calls that are slow outliers
# TAU_GENERATOR_DUMMY_OUTLIER_FACTOR=2   # outlier latency upper bound = timeout * this
# TAU_GENERATOR_DUMMY_FAILURE_RATE=0.1   # fraction returning unusable output

# --- judge worker (tuning; defaults shown, all optional) ---------------------
# Shares OPENROUTER_API_KEY above (required unless TAU_JUDGE_USE_DUMMY_LLM=1).
TAU_JUDGE_MODEL=z-ai/glm-5.2
TAU_JUDGE_PROVIDER_ONLY=z-ai/fp8
TAU_JUDGE_PROVIDER_ALLOW_FALLBACKS=false
TAU_JUDGE_CONCURRENCY=5      # judgments in flight at once
TAU_JUDGE_ATTEMPTS=4         # LLM tries per round
TAU_JUDGE_LLM_TIMEOUT=120    # per-attempt LLM timeout (seconds)
TAU_JUDGE_TOTAL_TIMEOUT=300  # cap on one round's total judging time (seconds)
TAU_JUDGE_POLL_SECONDS=10    # idle sleep between DB polls

# Token-free dummy judge for testing: fabricate random verdicts locally, spending
# zero LLM tokens (OPENROUTER_API_KEY not required). Off by default. Same latency /
# failure model as the task-generator dummy above.
# TAU_JUDGE_USE_DUMMY_LLM=1
# TAU_JUDGE_DUMMY_AVG_LATENCY=2          # median body latency (seconds)
# TAU_JUDGE_DUMMY_LATENCY_SIGMA=0.4      # log-space spread of the body
# TAU_JUDGE_DUMMY_SLOW_RATE=0.05         # fraction of calls that are slow outliers
# TAU_JUDGE_DUMMY_OUTLIER_FACTOR=2       # outlier latency upper bound = timeout * this
# TAU_JUDGE_DUMMY_FAILURE_RATE=0.1       # fraction returning unusable output

# --- submission security qualification (optional prompt/rendering knobs) -----
# Worker keeps this many live queue-head submissions qualified ahead of duels.
TAU_QUALIFICATION_WINDOW_SIZE=3
TAU_QUALIFICATION_POLL_SECONDS=10
TAU_QUALIFICATION_LLM_TIMEOUT=120
TAU_QUALIFICATION_MAX_TOKENS=16000
# Optional current public base harness path (file or directory). Missing/unset means
# degraded qualification mode; the worker records base_files_available=false.
# TAU_QUALIFICATION_BASE_PATH=/srv/tau/base-agent

# Optional prompt/rendering knobs for the reusable qualification utility.
# TAU_SECURITY_QUALIFICATION_MODEL=google/gemini-3.1-flash-lite
# TAU_SECURITY_QUALIFICATION_AGENT_ENTRYPOINT=agent.py
# TAU_SECURITY_QUALIFICATION_PATCH_MAX_CHARS=120000
# TAU_SECURITY_QUALIFICATION_BASE_ENTRYPOINT_MAX_CHARS=80000
# TAU_SECURITY_QUALIFICATION_SUBMITTED_ENTRYPOINT_MAX_CHARS=120000
# TAU_SECURITY_QUALIFICATION_BASE_FILES_MAX_CHARS=120000
# TAU_SECURITY_QUALIFICATION_SUBMITTED_FILES_MAX_CHARS=160000

# --- Duel pool targets (shared PoolTargets) ----------------------------------
# Tasks to keep per pool for the reigning king (default 50 each).
TAU_POOL_ONE_TARGET=50
TAU_POOL_TWO_TARGET=50

# --- duel-resolver worker ----------------------------------------------------
# How each pool is resolved. Accepted values are exact: round_wins or mean.
# round_wins: challenger needs wins > losses + TAU_DUEL_ROUND_WIN_MARGIN.
# mean: waits for the full pool, then challenger_mean - king_mean must clear
# TAU_DUEL_MEAN_SCORE_MARGIN.
TAU_DUEL_SCORING_METHOD=round_wins
TAU_DUEL_ROUND_WIN_MARGIN=0
TAU_DUEL_MEAN_SCORE_MARGIN=0.05
TAU_DUEL_POLL_SECONDS=5

# --- task-solver worker ------------------------------------------------------
# Runs miner agents in locked-down sandboxes (docker-out-of-docker; the compose
# service mounts /var/run/docker.sock). The agent reaches the model only through an
# in-process proxy on a per-solve internet-less network — the upstream key below is
# injected by the proxy and never enters the sandbox.
#
# LLM upstream the proxy forwards to. Switch provider with one var:
#   openrouter -> OPENROUTER_API_KEY (+ optional OPENROUTER_UPSTREAM_BASE_URL)
#   ninja      -> our own backend: NINJA_INFERENCE_BASE_URL + NINJA_INFERENCE_API_KEY
#   custom     -> any OpenAI-compatible: LLM_UPSTREAM_BASE_URL + LLM_UPSTREAM_API_KEY
# For local/remote inference replicas, use the *_BASE_URLS plural vars with
# comma-separated OpenAI-compatible bases. The solver proxy round-robins requests.
LLM_PROVIDER=openrouter
# NINJA_INFERENCE_BASE_URLS=http://<solver-host>:8000/v1,http://<solver-host>:8001/v1
# NINJA_INFERENCE_BASE_URL=http://ninja:8000/v1
# NINJA_INFERENCE_API_KEY=
# LLM_UPSTREAM_BASE_URLS=http://<solver-host>:8000/v1,http://<solver-host>:8001/v1
# LLM_UPSTREAM_BASE_URL=
# LLM_UPSTREAM_API_KEY=

# Model the proxy forces every agent request onto (provider-appropriate slug).
SOLVER_MODEL=Qwen/Qwen3.6-27B-FP8
# Max sandboxes run CONCURRENTLY per tick (also the per-tick job batch size).
MAX_CONTAINERS=4
# Idle sleep between ticks (seconds).
TAU_SOLVER_POLL_SECONDS=30
# King must change at least this many diff lines to QUALIFY a task.
TAU_SOLVER_QUALIFY_MIN_CHANGED_LINES=1
# Wait until the active pool has target QUALIFIED tasks before duel solves.
TAU_SOLVER_REQUIRE_FULL_POOL_FOR_DUELS=false

# Where extracted miner submissions live: one folder per submission, named by its
# submission id; each is an agent bundle whose entry point is agent.py. The compose
# task-solver service mounts this path read-only into the worker at the same path.
TAU_SUBMISSIONS_DIR=/home/robert/repos/s66_repositories/submissions
# Per-solve work trees are assembled here and bind-mounted into each sandbox. Under
# docker-out-of-docker (compose) it MUST be the same path on host and in the worker
# container — the compose service bind-mounts it same-path. On a host run, leave it
# unset to use the system temp dir.
TAU_SANDBOX_WORK_ROOT=/var/lib/tau/sandbox-work

# Per-solve spend caps (any unset = unbounded for that dimension). Strongly advised
# since untrusted miner code drives the spend.
# SOLVER_MAX_REQUESTS=200
# SOLVER_MAX_TOTAL_TOKENS=2000000
# SOLVER_MAX_COST=2.0
# SOLVER_MAX_TOKENS_PER_REQUEST=32000

# How long one upstream LLM call may take before the proxy times it out (seconds; the
# httpx read timeout). A timeout counts as a miner-unrelated infra fault, so the solve
# is retried rather than persisted. Default 600.
TAU_PROXY_REQUEST_TIMEOUT_SECONDS=600

# Sandbox resource limits / hardening (defaults shown, all optional).
# TAU_SANDBOX_MEMORY=2g
# TAU_SANDBOX_CPUS=1.0
# TAU_SANDBOX_PIDS_LIMIT=256
# TAU_SANDBOX_HARD_TIMEOUT_SECONDS=600
# TAU_SANDBOX_FIRST_TOKEN_TIMEOUT_SECONDS=300

# --- Axiom.co observability (optional) ---------------------------------------
# Structured solver events (qualification/solution/sandbox/exception) are sent to
# Axiom when all three are set AND the axiom-py extra is installed; otherwise the
# sink is a silent no-op. AXIOM_ENVIRON is a free-form tag (e.g. prod/staging).
# AXIOM_TOKEN=xaat-...
# AXIOM_DATASET=tau-solver
# AXIOM_ENVIRON=prod
